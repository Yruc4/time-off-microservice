{
  "name": "time-off-microservice",
  "version": "1.0.0",
  "description": "High-reliability Time-Off Microservice synchronized with HCM (Source of Truth)",
  "scripts": {
    "build": "nest build",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --runInBand",
    "test:unit": "jest --testPathPattern=unit --runInBand",
    "test:int": "jest --testPathPattern=integration --runInBand",
    "test:concurrency": "jest --testPathPattern=concurrency --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "sql.js": "^1.12.0",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/sql.js": "^1.4.9",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
